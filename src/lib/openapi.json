  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "admin@example.com"
          },
          "password": {
            "type": "string",
            "minLength": 6,
            "example": "password123"
          }
        }
      },
      "Token": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "Access Token"
          },
          "refresh_token": {
            "type": "string",
            "description": "Refresh Token"
          },
          "token_type": {
            "type": "string",
            "description": "Token Type",
            "example": "Bearer"
          },
          "company_id": {
            "type": "integer",
            "nullable": true,
            "description": "Company Id"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": {
            "$ref": "#/components/schemas/Token"
          }
        }
      },
      "RefreshTokenRequest": {
        "type": "object",
        "required": ["refresh_token"],
        "properties": {
          "refresh_token": {
            "type": "string",
            "description": "Refresh token to get new access token"
          }
        }
      },
      "RefreshTokenResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "New access token"
          },
          "refresh_token": {
            "type": "string",
            "description": "New refresh token"
          },
          "token_type": {
            "type": "string",
            "description": "Token type (usually 'Bearer')"
          },
          "company_id": {
            "type": "integer",
            "nullable": true,
            "description": "Company ID"
          }
        }
      },
      "GetMembersResponse": {
        "type": "object",
        "properties": {
          "members": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MemberListItem"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        }
      },
      "MemberListItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "member_number": {
            "type": "string"
          },
          "name_kanji": {
            "type": "string"
          },
          "name_kana": {
            "type": "string"
          },
          "member_type": {
            "type": "string",
            "enum": ["regular", "family", "corporate", "company_discount"]
          },
          "status": {
            "type": "string",
            "enum": ["active", "suspended", "withdrawn", "force_withdrawn"]
          },
          "store_name": {
            "type": "string"
          },
          "brand": {
            "type": "string",
            "enum": ["joyfit", "fit365"]
          },
          "contract_plan_name": {
            "type": "string"
          },
          "joined_at": {
            "type": "string",
            "format": "date"
          },
          "last_visit_date": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "has_unpaid": {
            "type": "boolean"
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          },
          "total_pages": {
            "type": "integer"
          }
        }
      },
      "GetMemberDetailResponse": {
        "type": "object",
        "properties": {
          "member": {
            "type": "object"
          }
        }
      },
      "UpdateBasicInfoRequest": {
        "type": "object",
        "properties": {
          "name_kanji": {
            "type": "string"
          },
          "name_kana": {
            "type": "string"
          },
          "postal_code": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "PointAdjustmentRequest": {
        "type": "object",
        "required": ["type", "points", "reason"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["add", "subtract"]
          },
          "points": {
            "type": "integer",
            "minimum": 1
          },
          "reason": {
            "type": "string",
            "minLength": 10,
            "maxLength": 500
          }
        }
      },
      "CreateMemoRequest": {
        "type": "object",
        "required": ["type", "content"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["caution", "vip", "other"],
            "description": "メモ種別（要注意/VIP/その他）"
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000,
            "description": "メモ内容（1000文字まで）"
          },
          "created_by": {
            "type": "string",
            "description": "記録スタッフ（未指定時はAPIでデフォルト設定）"
          }
        }
      },
      "UpdateMemoRequest": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["caution", "vip", "other"]
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      },
      "StaffMemo": {
        "type": "object",
        "required": ["id", "date", "type", "content", "created_by"],
        "properties": {
          "id": {
            "type": "string",
            "description": "メモID"
          },
          "date": {
            "type": "string",
            "format": "date-time",
            "description": "記録日時"
          },
          "type": {
            "type": "string",
            "enum": ["caution", "vip", "other"],
            "description": "メモ種別"
          },
          "content": {
            "type": "string",
            "description": "メモ内容"
          },
          "created_by": {
            "type": "string",
            "description": "記録スタッフ"
          }
        }
      },
      "CreateMemoResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "memo": {
            "$ref": "#/components/schemas/StaffMemo"
          }
        }
      },
      "UpdateMemoResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "memo": {
            "$ref": "#/components/schemas/StaffMemo"
          }
        }
      },
      "ExportMembersRequest": {
        "type": "object",
        "required": ["format", "target", "fields"],
        "properties": {
          "format": {
            "type": "string",
            "enum": ["csv", "excel"]
          },
          "target": {
            "type": "string",
            "enum": ["selected", "filtered"]
          },
          "member_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "GetCommunicationsResponse": {
        "type": "object",
        "description": "コミュニケーションタブ取得レスポンス",
        "properties": {
          "memos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StaffMemo"
            },
            "description": "スタッフメモ一覧"
          },
          "inquiries": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "date": {
                  "type": "string",
                  "format": "date-time"
                },
                "content": {
                  "type": "string"
                },
                "staff_name": {
                  "type": "string"
                },
                "result": {
                  "type": "string"
                },
                "status": {
                  "type": "string",
                  "enum": ["in_progress", "completed"]
                }
              }
            }
          },
          "notifications": {
            "type": "object"
          },
          "phoneRecords": {
            "type": "array"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}
