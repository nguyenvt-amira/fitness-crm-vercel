    "/crm/members": {
      "get": {
        "tags": ["Members"],
        "summary": "Get members list",
        "description": "Retrieve paginated list of members with filters and sorting",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            },
            "description": "Items per page"
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search by member number, name, phone, or email"
          },
          {
            "name": "member_type",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["regular", "family", "corporate", "company_discount"]
              }
            },
            "description": "Filter by member type"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["active", "suspended", "withdrawn", "force_withdrawn"]
              }
            },
            "description": "Filter by status"
          },
          {
            "name": "brand",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["joyfit", "fit365"]
              }
            },
            "description": "Filter by brand"
          },
          {
            "name": "store_id",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Filter by store ID"
          },
          {
            "name": "contract_plan_id",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Filter by contract plan ID"
          },
          {
            "name": "last_visit_days",
            "in": "query",
            "schema": {
              "type": "integer",
              "description": "Filter by last visit days (7=1週間以内, 30=1ヶ月以内, 90=3ヶ月以内, -1=3ヶ月以上)"
            },
            "description": "Filter by last visit date range"
          },
          {
            "name": "has_unpaid",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Filter by unpaid status"
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["member_number", "joined_at", "last_visit", "name"],
              "default": "member_number"
            },
            "description": "Sort field"
          },
          {
            "name": "sort_order",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["asc", "desc"],
              "default": "asc"
            },
            "description": "Sort order"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetMembersResponse"
                }
              }
            }
          }
        }
      }
    },
