{
  "openapi": "3.1.0",
  "info": {
    "title": "Fitness CRM",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api/crm"
    }
  ],
  "tags": [
    {
      "name": "Members",
      "description": "Member list, search, export, etc."
    },
    {
      "name": "MemberDetails",
      "description": "Retrieve and update member details (by tabs)"
    },
    {
      "name": "Points",
      "description": "Point management (Headquarter only)"
    },
    {
      "name": "Memos",
      "description": "Staff memo management"
    }
  ],
  "paths": {
    "/members": {
      "get": {
        "tags": ["Members"],
        "summary": "Get members list (pagination, filtering, sorting)",
        "operationId": "getMembers",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50,
              "enum": [50, 100, 200]
            }
          },
          {
            "name": "keyword",
            "in": "query",
            "description": "Member number, name, phone number, email, etc.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "storeId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "memberType",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "lastVisitDate",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort fields. Example: name:asc,createdAt:desc",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Member list and pagination info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedMembersResponse"
                }
              }
            }
          }
        }
      }
    },
    "/members/search": {
      "get": {
        "tags": ["Members"],
        "summary": "Member search (for quick search using keyword or QR scanning)",
        "operationId": "searchMembers",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search result list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MemberListItem"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/members/export": {
      "post": {
        "tags": ["Members"],
        "summary": "Execute export",
        "operationId": "exportMembers",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "format": {
                    "type": "string",
                    "enum": ["csv", "excel"]
                  },
                  "target": {
                    "type": "string",
                    "enum": ["selected", "filtered_all"]
                  },
                  "memberIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "fields": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Export job accepted, or file download URL"
          }
        }
      }
    },
    "/members/{id}": {
      "get": {
        "tags": ["MemberDetails"],
        "summary": "Get member details (Header common info)",
        "operationId": "getMemberById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Member summary (alerts, badges, status, etc.)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemberDetailHeader"
                }
              }
            }
          }
        }
      }
    },
    "/members/{id}/basic-info": {
      "get": {
        "tags": ["MemberDetails"],
        "summary": "Get Basic Info tab data",
        "operationId": "getMemberBasicInfo",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemberBasicInfo"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["MemberDetails"],
        "summary": "Update Basic Info",
        "operationId": "updateMemberBasicInfo",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateBasicInfoRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          }
        }
      }
    },
    "/members/{id}/health-info": {
      "put": {
        "tags": ["MemberDetails"],
        "summary": "Update Health Info",
        "operationId": "updateMemberHealthInfo",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "healthDeclaration": {
                    "type": "string"
                  },
                  "medicalHistory": {
                    "type": "string"
                  },
                  "allergies": {
                    "type": "string"
                  },
                  "exerciseRestrictions": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          }
        }
      }
    },
    "/members/{id}/marketing-consent": {
      "put": {
        "tags": ["MemberDetails"],
        "summary": "Update Marketing Consent",
        "operationId": "updateMemberMarketingConsent",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "emailConsent": {
                    "type": "boolean"
                  },
                  "smsConsent": {
                    "type": "boolean"
                  },
                  "pushConsent": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          }
        }
      }
    },
    "/members/{id}/contracts": {
      "get": {
        "tags": ["MemberDetails"],
        "summary": "Get Contracts tab data",
        "operationId": "getMemberContracts",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/members/{id}/points": {
      "get": {
        "tags": ["MemberDetails"],
        "summary": "Get Points tab data (by brand)",
        "operationId": "getMemberPoints",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/members/{id}/usage-history": {
      "get": {
        "tags": ["MemberDetails"],
        "summary": "Get Usage History tab data",
        "operationId": "getMemberUsageHistory",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/members/{id}/training-records": {
      "get": {
        "tags": ["MemberDetails"],
        "summary": "Get Training Records tab data",
        "operationId": "getMemberTrainingRecords",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/members/{id}/service-usage": {
      "get": {
        "tags": ["MemberDetails"],
        "summary": "Get Service Usage tab data",
        "operationId": "getMemberServiceUsage",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/members/{id}/communications": {
      "get": {
        "tags": ["MemberDetails"],
        "summary": "Get Communications tab data",
        "operationId": "getMemberCommunications",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/members/{id}/change-history": {
      "get": {
        "tags": ["MemberDetails"],
        "summary": "Get Change History tab data",
        "operationId": "getMemberChangeHistory",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/members/{id}/relationships": {
      "get": {
        "tags": ["MemberDetails"],
        "summary": "Get Relationships tab data",
        "operationId": "getMemberRelationships",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/members/{id}/audit-logs": {
      "get": {
        "tags": ["MemberDetails"],
        "summary": "Get Audit Logs (Access logs, etc.)",
        "operationId": "getMemberAuditLogs",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/members/{id}/points/adjust": {
      "post": {
        "tags": ["Points"],
        "summary": "Adjust Points (Headquarter only)",
        "operationId": "adjustMemberPoints",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["type", "points", "reason"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["add", "subtract"]
                  },
                  "points": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "reason": {
                    "type": "string",
                    "minLength": 10,
                    "maxLength": 500
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Point adjustment result"
          }
        }
      }
    },
    "/members/{id}/memos": {
      "post": {
        "tags": ["Memos"],
        "summary": "Add Memo",
        "operationId": "createMemberMemo",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["memoType", "content"],
                "properties": {
                  "memoType": {
                    "type": "string",
                    "enum": ["warning", "vip", "other"]
                  },
                  "content": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 1000
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/members/{id}/memos/{memo_id}": {
      "put": {
        "tags": ["Memos"],
        "summary": "Update Memo",
        "operationId": "updateMemberMemo",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "memo_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["memoType", "content"],
                "properties": {
                  "memoType": {
                    "type": "string",
                    "enum": ["warning", "vip", "other"]
                  },
                  "content": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 1000
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          }
        }
      },
      "delete": {
        "tags": ["Memos"],
        "summary": "Delete Memo",
        "operationId": "deleteMemberMemo",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "memo_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PaginatedMembersResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MemberListItem"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/PaginationInfo"
          }
        }
      },
      "PaginationInfo": {
        "type": "object",
        "properties": {
          "currentPage": {
            "type": "integer"
          },
          "totalPages": {
            "type": "integer"
          },
          "totalItems": {
            "type": "integer"
          },
          "itemsPerPage": {
            "type": "integer"
          }
        }
      },
      "MemberListItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "memberNo": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "memberType": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "storeName": {
            "type": "string"
          },
          "brandId": {
            "type": "string"
          },
          "mainPlan": {
            "type": "string"
          },
          "joinDate": {
            "type": "string",
            "format": "date"
          },
          "lastVisitDate": {
            "type": "string",
            "format": "date-time"
          },
          "hasUnpaid": {
            "type": "boolean"
          }
        }
      },
      "MemberDetailHeader": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "memberNo": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "nameKana": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "brandId": {
            "type": "string"
          },
          "storeName": {
            "type": "string"
          },
          "alerts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "MemberBasicInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        }
      },
      "UpdateBasicInfoRequest": {
        "type": "object",
        "required": [
          "name",
          "nameKana",
          "zipCode",
          "prefecture",
          "city",
          "addressLine",
          "phone",
          "email"
        ],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 50
          },
          "nameKana": {
            "type": "string",
            "maxLength": 50
          },
          "zipCode": {
            "type": "string",
            "pattern": "^[0-9]{7}$"
          },
          "prefecture": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "addressLine": {
            "type": "string"
          },
          "buildingName": {
            "type": "string"
          },
          "phone": {
            "type": "string",
            "pattern": "^[0-9]{10,11}$"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "emergencyContactName": {
            "type": "string"
          },
          "emergencyContactRelation": {
            "type": "string"
          },
          "emergencyContactPhone": {
            "type": "string",
            "pattern": "^[0-9]{10,11}$"
          }
        }
      }
    }
  }
}
