{
  "name": "fitness-crm",
  "version": "0.1.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "private": true,
  "scripts": {
    "dev": "tsx src/lib/routes/scripts/generate-routes.ts && tsx concurrently.ts",
    "build": "tsx src/lib/routes/scripts/generate-routes.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json",
    "format": "prettier --write ./src",
    "prepare": "husky",
    "generate-routes": "tsx src/lib/routes/scripts/generate-routes.ts",
    "generate-openapi": "tsx src/app/api/_scripts/generate-openapi-from-zod.ts",
    "openapi-ts": "openapi-ts",
    "generate-api": "dotenv -e .env -- openapi-ts -f ./openapi-ts.config.ts",
    "generate-client": "openapi-ts -f ./openapi-ts.config.ts"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "@base-ui/react": "^1.4.1",
    "@holiday-jp/holiday_jp": "^2.5.1",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.6.5",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "swagger-ui-react": "^5.32.0",
    "tailwind-merge": "^3.6.0",
    "universal-cookie": "^8.0.1",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.93.1",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/swagger-ui-react": "^5.18.0",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
